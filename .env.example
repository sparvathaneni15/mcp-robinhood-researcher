ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password

# ── Auth path 1: Passkey / token injection (recommended if TOTP is unavailable) ──
# Get these from Chrome DevTools while logged into robinhood.com:
#   Network tab → any api.robinhood.com request → Headers → "Authorization: Bearer <TOKEN>"
#   For refresh token: Network tab → filter "oauth2/token" → Response body → "refresh_token"
ROBINHOOD_ACCESS_TOKEN=
ROBINHOOD_REFRESH_TOKEN=

# ── Auth path 2: TOTP / Google Authenticator (legacy) ──
# Robinhood app -> Settings -> Security -> Two-Factor Auth -> "Can't scan QR code?"
ROBINHOOD_TOTP_SECRET=

MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Public base URL of the Robinhood MCP server (used to build OAuth issuer/resource URLs).
# Format: https://<tailscale-machine-name>.<tailnet>/robinhood
MCP_BASE_URL=https://beast-pc.tail856667.ts.net/robinhood
