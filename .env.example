ROBINHOOD_DEVICE_TOKEN=your-device-token-uuid

# Get from Chrome DevTools while logged into robinhood.com:
#   Network tab → any api.robinhood.com request → Authorization: Bearer <TOKEN>
ROBINHOOD_ACCESS_TOKEN=

# Optional but recommended — keeps the session alive without a container restart.
# Network tab → filter "oauth2/token" → Response body → "refresh_token"
ROBINHOOD_REFRESH_TOKEN=

MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Public base URL of this server — used to build OAuth issuer/resource URLs.
# Format: https://<tailscale-machine>.<tailnet>/robinhood
MCP_BASE_URL=https://beast-pc.tail856667.ts.net/robinhood
